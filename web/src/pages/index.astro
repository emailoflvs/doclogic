                  class="absolute inset-0 w-full h-full block"
                  title="Видео: как работает DocLogic"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                />
              </div>
            </div>
          </div>

          <script is:inline>
            (function() {
              const wrap = document.getElementById('youtube-embed-wrapper');
              const container = wrap?.querySelector('.youtube-embed-container');
              const iframe = container?.querySelector('iframe');
              if (!container || !iframe) return;

              fetch('/api/config')
                .then(r => r.json())
                .then(data => {
                  const id = data?.youtubeVideoId;
                  if (id && typeof id === 'string' && id.trim()) {
                    iframe.src = 'https://www.youtube.com/embed/' + id.trim() + '?rel=0&modestbranding=1&iv_load_policy=3';
                    container.style.display = '';
                    wrap.setAttribute('aria-hidden', 'false');
                  }
                })
                .catch(() => {});
            })();
          </script>
