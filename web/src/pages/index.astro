    <script is:inline>
      (function () {
        document.querySelectorAll('#faq details').forEach((item) => {
          item.addEventListener('toggle', () => {
            if (!item.open) return;
            const question = item.querySelector('summary span')?.textContent?.trim() || 'FAQ';
            window.dlTrack?.('faq_open', {
              faq_question: question
            });
          });
        });
      })();
    </script>

    <script is:inline>
      (function () {
        let sent = false;

        const onScroll = () => {
          if (sent) return;

          const doc = document.documentElement;
          const max = doc.scrollHeight - window.innerHeight;
          if (max <= 0) return;

          const depth = ((window.scrollY || doc.scrollTop) / max) * 100;
          if (depth >= 50) {
            sent = true;
            window.dlTrack?.('scroll_50', {
              page_path: window.location.pathname
            });
            window.removeEventListener('scroll', onScroll);
          }
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      })();
    </script>

    <script is:inline>
      (function () {
        const form = document.getElementById('leadForm');
        if (!form) return;

        let started = false;
        form.addEventListener('focusin', () => {
          if (started) return;
          started = true;
          window.dlTrack?.('lead_form_start', {
            form_id: 'leadForm',
            placement: 'request_section'
          });
        });
      })();
    </script>

    <script is:inline>
      const form = document.getElementById('leadForm');
      const msg = document.getElementById('formMsg');
      const submitBtn = document.getElementById('submitBtn');

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        msg.textContent = '';

        const email = (document.getElementById('email')?.value || '').trim();
        const phone = (document.getElementById('phone')?.value || '').trim();

        if (!email && !phone) {
          window.dlTrack?.('lead_validation_error', {
            form_id: 'leadForm',
            reason: 'missing_contact'
          });

          msg.textContent = 'Укажите email или телефон — любой контакт подходит.';
          msg.className = 'small mt-3 text-red-600';
          return;
        }

        submitBtn.disabled = true;
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Отправка...';
        submitBtn.style.opacity = '0.7';
        submitBtn.style.cursor = 'not-allowed';

        const fd = new FormData(form);

        const redirectToThanks = () => {
          window.location.href = '/thanks';
        };

        const sendLeadAndRedirect = () => {
          const attribution = window.dlGetAttribution?.() || {};
          sessionStorage.setItem('dl_lead_pending', '1');

          if (typeof window.gtag !== 'function') {
            redirectToThanks();
            return;
          }

          let done = false;
          const finish = () => {
            if (done) return;
            done = true;
            redirectToThanks();
          };

          window.gtag('event', 'generate_lead', {
            form_id: 'leadForm',
            lead_type: 'demo_request',
            utm_source: attribution.utm_source || '',
            utm_medium: attribution.utm_medium || '',
            utm_campaign: attribution.utm_campaign || '',
            landing_page: attribution.landing_page || window.location.pathname,
            referrer_host: attribution.referrer_host || '',
            event_callback: finish
          });

          setTimeout(finish, 800);
        };

        try {
          const res = await fetch('/api/lead', { method: 'POST', body: fd });
          if (!res.ok) throw new Error(await res.text());

          const data = await res.json();
          const criticalChannels = ['email', 'telegram'];
          const criticalResults = criticalChannels.map(key => data.results?.[key]).filter(Boolean);
          const criticalHasErrors = criticalResults.some(r => r.error);
          const criticalHasSuccess = criticalResults.some(r => r.ok);
          const criticalAllSkipped = criticalResults.length > 0 && criticalResults.every(r => r.skipped && !r.ok);

          if (criticalHasErrors) {
            window.dlTrack?.('lead_notification_error', {
              form_id: 'leadForm'
            });

            msg.textContent = 'Запрос отправлен, но возникли ошибки при уведомлении. Проверьте логи сервера.';
            msg.className = 'small mt-3 text-yellow-600';
          } else if (criticalAllSkipped) {
            window.dlTrack?.('lead_notification_skipped', {
              form_id: 'leadForm'
            });

            msg.textContent = 'Запрос отправлен. Уведомления не настроены.';
            msg.className = 'small mt-3 text-yellow-600';
          } else if (criticalHasSuccess) {
            sendLeadAndRedirect();
            return;
          } else {
            sendLeadAndRedirect();
            return;
          }
        } catch (err) {
          window.dlTrack?.('lead_submit_error', {
            form_id: 'leadForm'
          });

          msg.textContent = 'Не удалось отправить. Проверьте соединение и попробуйте ещё раз.';
          msg.className = 'small mt-3 text-red-600';
          console.error('Ошибка отправки:', err);
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = originalText;
          submitBtn.style.opacity = '1';
          submitBtn.style.cursor = 'pointer';
        }
      });
    </script>
  </body>
</html>