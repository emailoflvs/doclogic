    <script is:inline>
      (function () {
        const params = new URLSearchParams(window.location.search);
        const keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid', 'msclkid', 'yclid'];
        const current = window.dlReadAttribution?.() || {};
        let changed = false;

        keys.forEach((key) => {
          const value = (params.get(key) || '').trim();
          if (value && current[key] !== value) {
            current[key] = value;
            changed = true;
          }
        });

        if (!current.landing_page) {
          current.landing_page = window.location.pathname + window.location.search;
          changed = true;
        }

        if (!current.referrer_host && document.referrer) {
          try {
            current.referrer_host = new URL(document.referrer).hostname;
            changed = true;
          } catch {}
        }

        if (changed) {
          window.dlWriteAttribution?.(current);
        }

        const hiddenFields = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid', 'msclkid', 'yclid', 'landing_page', 'referrer_host'];
        hiddenFields.forEach((key) => {
          const input = document.getElementById(key);
          if (input) {
            input.value = current[key] || '';
          }
        });
      })();
    </script>

    <script is:inline>
      (function () {
        const resolvePlacement = (el) => {
          return (
            el.dataset.gaPlacement ||
            el.closest('section[id]')?.id ||
            el.closest('[id]')?.id ||
            'unknown'
          );
        };

        document.querySelectorAll('[data-ga-event]').forEach((el) => {
          el.addEventListener('click', () => {
            window.dlTrack?.(el.dataset.gaEvent, {
              placement: resolvePlacement(el),
              label: el.dataset.gaLabel || el.textContent?.trim() || ''
            });
          });
        });

        document.addEventListener('click', (e) => {
          const link = e.target.closest('a');
          if (!link) return;
          if (link.dataset.gaEvent) return;

          const href = link.getAttribute('href') || '';
          const placement = resolvePlacement(link);
          const label = link.textContent?.trim() || href;

          if (href.startsWith('mailto:')) {
            window.dlTrack?.('email_click', {
              placement,
              label: href.replace('mailto:', '')
            });
            return;
          }

          if (href.startsWith('tel:')) {
            window.dlTrack?.('phone_click', {
              placement,
              label: href.replace('tel:', '')
            });
            return;
          }

          if (/wa\.me|api\.whatsapp\.com|whatsapp:/i.test(href)) {
            window.dlTrack?.('whatsapp_click', {
              placement,
              label
            });
            return;
          }

          if (/t\.me\/|telegram\.me\//i.test(href)) {
            window.dlTrack?.('telegram_click', {
              placement,
              label
            });
            return;
          }

          if (/\.(pdf|doc|docx|xls|xlsx|csv|zip)(\?|#|$)/i.test(href)) {
            window.dlTrack?.('download_click', {
              placement,
              label: href
            });
          }
        });
      })();
    </script>

    <script is:inline>
      (function () {
        const trigger = document.getElementById('hero-video-trigger');
        const iframe = document.getElementById('hero-video-iframe');
        if (!trigger || !iframe) return;

        trigger.addEventListener('click', () => {
          window.dlTrack?.('hero_video_open', {
            placement: 'hero',
            video_id: 'D0UoSqo5kzo'
          });

          const src = iframe.getAttribute('data-src');
          if (src && !iframe.getAttribute('src')) iframe.setAttribute('src', src);
          iframe.classList.remove('hidden');
          trigger.classList.add('hidden');
        }, { once: true });
      })();
    </script>

    <script is:inline>
      (function () {
        const links = Array.from(document.querySelectorAll('header nav a[href^="#"]'));
        if (!links.length) return;

        const sections = links.map(a => document.querySelector(a.getAttribute('href'))).filter(Boolean);

        const setActive = (id) => {
          links.forEach(a => {
            const href = a.getAttribute('href') || '';
            a.classList.toggle('nav-link--active', href === '#' + id);
          });
        };

        if (location.hash) {
          const id = location.hash.replace('#', '');
          if (document.getElementById(id)) setActive(id);
        }

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries.filter(e => e.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
            if (visible?.target?.id) setActive(visible.target.id);
          },
          {
            root: null,
            rootMargin: '-35% 0px -55% 0px',
            threshold: [0, 0.1, 0.25, 0.5, 0.75, 1],
          }
        );

        sections.forEach(s => observer.observe(s));
        links.forEach(a => a.addEventListener('click', () => {
          const id = (a.getAttribute('href') || '').replace('#', '');
          if (id) setActive(id);
        }));
      })();
    </script>

    <script is:inline>
      (function () {
