                  class="mt-2 w-full rounded-2xl border 
                  border-slate-200 bg-white px-4 py-3 text-sm" value="5" />
                </div>

                <div>
                  <label class="text-sm font-medium" for="roi_rate">
                  Стоимость часа сотрудника, €</label>
                  <input id="roi_rate" inputmode="decimal" 
                  class="mt-2 w-full rounded-2xl border border-slate-200 
                  bg-white px-4 py-3 text-sm" value="15" />
                </div>

                <div>
                  <label class="text-sm font-medium" for="roi_errors">Ошибок в месяц</label>
                  <input id="roi_errors" inputmode="numeric" 
                  class="mt-2 w-full rounded-2xl border 
                  border-slate-200 bg-white px-4 py-3 text-sm" value="20" />
                </div>

                <div>
                  <label class="text-sm font-medium" for="roi_error_cost">Цена одной ошибки, €</label>
                  <input id="roi_error_cost" inputmode="decimal" 
                  class="mt-2 w-full rounded-2xl border 
                  border-slate-200 bg-white px-4 py-3 text-sm" value="30" />
                </div>

                <div class="sm:col-span-2">
                  <label class="text-sm font-medium" for="roi_monthly_cost">Стоимость DocLogic, €/мес</label>
                  <input id="roi_monthly_cost" inputmode="numeric" 
                  class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm" value="200" />
                </div>
              </div>
<!--
              <details class="mt-4 rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
                <!--<summary class="cursor-pointer text-sm font-semibold 
                text-slate-900">Допущения расчёта</summary>
                -->
                <div class="mt-3 grid gap-3 sm:grid-cols-2">
                  <!-- После AI сотрудник быстро просматривает результат 
                   <div class="sm:col-span-2 text-sm text-slate-600">
                    и подтверждает выгрузку в web-форме.
                    
                  </div>
                  -->
                  <!--
                  <div>
                    <label class="text-sm font-medium" for="roi_after">Минут на проверку после DocLogic</label>
                    <input id="roi_after" inputmode="decimal" class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm" value="0.5" />
                    <div class="mt-1 text-xs text-slate-500">По умолчанию: 0.5 мин (30 сек)</div>
                  </div>
                  -->
                </div>
              </details>
              <div class="mt-5 flex flex-wrap gap-3">
                <a
                  href="#request"
                  class="btn btn-primary"
                  data-ga-event="cta_click"
                  data-ga-placement="roi"
                  data-ga-label="Получить точный расчёт и демо"
                >
                  Получить точный расчёт и демо
                </a>
                <!-- <button id="roi_reset" type="button" class="btn btn-secondary">Вернуть пример</button> -->
              </div>
            </Card>

            <Card>
              <div class="text-lg font-semibold">Результат</div>
              <p class="mt-1 text-sm text-slate-600">
                Это ориентир. На демо покажем расчёт уже на Ваших документах и Вашей схеме выгрузки.
              </p>

              <div class="mt-5 grid gap-3">
                <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
                  <div class="text-sm font-semibold text-slate-600">
                  Экономия времени</div>
                  <div class="mt-1 text-2xl font-bold">
                    <span id="roi_out_hours">—</span><span class="text-xs font-normal text-slate-500 whitespace-nowrap"> часов / мес</span>
                  </div>
                </div>

                <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
                  <div class="text-sm font-semibold text-slate-600">Экономия на ручной обработке</div>
                  <div class="mt-1 text-2xl font-bold">
                    <span id="roi_out_labor">—</span><span class="text-xs font-normal text-slate-500 whitespace-nowrap"> / мес</span>
                  </div>
                </div>

                <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
                  <div class="text-sm font-semibold text-slate-600">Экономия на ошибках</div>
                  <div class="mt-1 text-2xl font-bold">
                    <span id="roi_out_errors">—</span><span class="text-xs font-normal text-slate-500 whitespace-nowrap"> / мес</span>
                  </div>
                </div>

                <div class="rounded-2xl bg-slate-900 p-4 text-white">
                  <div class="text-sm font-semibold 
                  text-white/70">Чистая выгода</div>
                  <div class="mt-1 text-3xl font-bold">
                    <span id="roi_out_total">
                    —</span><span class="text-xs 
                    font-normal text-white/70 
                    whitespace-nowrap"> / мес. </span>
                  </div>
                  <span class="mt-2 text-sm text-white/70">
                    <a href="#hidden-losses" class="underline text-white font-semibold hover:opacity-90">
                    Потери, которых здесь не видно</a>
                  </span>
                </div>
              </div>
            </Card>
          </FlexGrid>

          <script is:inline>
            (function () {
              const defaults = {
                docs: '180',
                minutes: '10',
                rate: '18',
                after: '0.5',
                errors: '6',
                errorCost: '45',
                monthlyCost: '200'
              };

              const $ = (id) => document.getElementById(id);
              const elDocs = $('roi_docs');
              const elMin = $('roi_minutes');
              const elRate = $('roi_rate');
              const elAfter = $('roi_after');
              const elErr = $('roi_errors');
              const elErrCost = $('roi_error_cost');
              const elMonthlyCost = $('roi_monthly_cost');
              const btnReset = $('roi_reset');

              const outHours = $('roi_out_hours');
              const outLabor = $('roi_out_labor');
              const outErrors = $('roi_out_errors');
              const outTotal = $('roi_out_total');

              const fmtEur = new Intl.NumberFormat('ru-RU', {
                style: 'currency',
                currency: 'EUR',
                maximumFractionDigits: 0,
              });

              const fmtNum = new Intl.NumberFormat('ru-RU', { maximumFractionDigits: 1 });

              const parse = (v) => {
                if (v == null) return NaN;
                const s = String(v).trim().replace(/\s+/g, '').replace(',', '.');
                if (!s) return NaN;
                const n = Number(s);
                return Number.isFinite(n) ? n : NaN;
              };

              const update = () => {
                const docs = parse(elDocs.value);
                const minutesManual = parse(elMin.value);
                const rate = parse(elRate.value);
                const minutesAfter = parse(elAfter?.value ?? 0.5);
                const errors = parse(elErr.value);
                const errorCost = parse(elErrCost.value);

                if (![docs, minutesManual, rate, minutesAfter].every((v) => Number.isFinite(v) && v >= 0)) {
                  outHours.textContent = '—';
                  outLabor.textContent = '—';
                  outErrors.textContent = '—';
                  outTotal.textContent = '—';
                  return;
                }

                const minutesSavedPerDoc = Math.max(0, minutesManual - minutesAfter);
                const hoursSaved = (docs * minutesSavedPerDoc) / 60;
                const laborEur = hoursSaved * rate;
                const errorsEur = Number.isFinite(errors) && Number.isFinite(errorCost) ? Math.max(0, errors) * Math.max(0, errorCost) : 0;
                const totalEur = laborEur + errorsEur;
                const monthlyCost = Number.isFinite(parse(elMonthlyCost?.value)) ? Math.max(0, parse(elMonthlyCost.value)) : 0;
                const netEur = totalEur - monthlyCost;

                outHours.textContent = fmtNum.format(hoursSaved);
                outLabor.textContent = fmtEur.format(laborEur);
                outErrors.textContent = fmtEur.format(errorsEur);
                outTotal.textContent = fmtEur.format(netEur);
              };

              [elDocs, elMin, elRate, elAfter, elErr, elErrCost, elMonthlyCost].forEach((el) => el?.addEventListener('input', update));

              btnReset?.addEventListener('click', () => {
                elDocs.value = defaults.docs;
                elMin.value = defaults.minutes;
                elRate.value = defaults.rate;
                elAfter.value = defaults.after;
                elErr.value = defaults.errors;
                elErrCost.value = defaults.errorCost;
                if (elMonthlyCost) elMonthlyCost.value = defaults.monthlyCost;
                update();
              });

              update();
            })();
          </script>
        </Container>
      </Section>

      <Section id="hidden-losses" padding="small">
        <Container>
          <div class="max-w-3xl">
            <h2 class="h2">Потери, которых не видно в калькуляторе</h2>
            <p class="p mt-2">
              Кроме прямой экономии есть ещё операционные риски, которые ручной ввод только усиливает.
            </p>
          </div>

          <FlexGrid cols={2} gap="md" class="mt-8 lg:grid-cols-2">
            <Card>
              <div class="text-lg font-semibold">Ручной ввод зависит от конкретных людей</div>
              <p class="p mt-3 text-sm">
                Если сотрудник заболел, ушёл в отпуск или уволился, нагрузка резко ложится на остальных.
                Новый человек работает медленнее и чаще ошибается.
              </p>
            </Card>
            <Card>
              <div class="text-lg font-semibold">При росте потока документов ручная обработка начинает тормозить бизнес</div>
              <p class="p mt-3 text-sm">
                Когда документов становится больше, ввод данных начинает задерживать поступления,
                учёт и работу команды. DocLogic снимает это ограничение.
