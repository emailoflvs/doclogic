---
import '../styles/global.css';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import FlexGrid from '../components/FlexGrid.astro';
import Card from '../components/Card.astro';

const year = new Date().getFullYear();
const buildId = new Date().toISOString().slice(0, 19).replace('T', ' ');
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="build-time" content={new Date().toISOString()} />

    <title>DocLogic — автоматизация ввода данных и документооборота</title>
    <meta
      name="description"
      content="DocLogic переносит данные из фото/сканов/PDF накладных в структурированные данные и выгружает в вашу систему (CRM/ERP/учёт) через API или файлом."
    />
    <link rel="icon" href="/assets/favicon.svg" />

    <style is:global>
      /* Active nav item (scrollspy) */
      .nav-link {
        position: relative;
        padding: 6px 0;
        transition: color 150ms ease;
      }
      .nav-link--active {
        color: #0f172a !important; /* slate-900 */
        font-weight: 600;
      }
      .nav-link--active::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -10px;
        height: 2px;
        background: rgba(15, 23, 42, 0.85);
        border-radius: 999px;
      }
    </style>
  </head>

  <body>
    <!-- Top Nav -->
    <header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/70 backdrop-blur">
      <div class="container flex h-16 items-center justify-between">
        <a href="#top" class="flex items-center gap-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-slate-900 text-white font-bold">DL</span>
          <span class="font-semibold">DocLogic</span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm text-slate-600">
          <a class="nav-link hover:text-slate-900" href="#how">Как работает</a>
          <a class="nav-link hover:text-slate-900" href="#benefits">Выгоды</a>
          <a class="nav-link hover:text-slate-900" href="#integrations">Интеграции</a>
          <a class="nav-link hover:text-slate-900" href="#differences">Отличия</a>
          <a class="nav-link hover:text-slate-900" href="#examples">Примеры</a>
          <a class="nav-link hover:text-slate-900" href="#custom">Настройка</a>
          <a class="nav-link hover:text-slate-900" href="#pricing">Внедрение и цена</a>
          <a class="nav-link hover:text-slate-900" href="#faq">FAQ</a>
        </nav>

        <a class="btn btn-primary" href="#request">Связаться с нами</a>
      </div>
    </header>

    <main id="top">
      <!-- Hero -->
      <Section>
        <Container>
          <FlexGrid cols={2} gap="lg" items="start" class="lg:grid-cols-2">
            <div>
              <div class="badge badge-lg">AI для ввода данных из документов</div>

              <h2 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight">
                Перестаньте платить за<br />ввод данных
              </h2>

              <p class="p mt-4 max-w-xl text-lg text-slate-700">
                Автоматический перенос данных из фото/PDF документов 
                на компьютер для передачи в
                <b> CRM / ERP / учётные и любые другие программы</b>.
              </p>

              <ul class="mt-6 space-y-3 text-lg text-slate-700">
                <li class="flex gap-3">
                  <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-900 text-white text-base">✓</span>
                  Экономия на вводе данных
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-900 text-white text-base">✓</span>
                  Минимизация ошибок
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-900 text-white text-base">✓</span>
                  Быстрое получение данных о новых поступлениях
                </li>
                <li class="flex gap-3">
                  <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-slate-900 text-white text-base">✓</span>
                  Программа настраивается специально для вас
                </li>
              </ul>

              <div class="mt-8 flex flex-wrap gap-3">
                <a class="btn btn-primary" href="#request">Связаться с нами</a>
              </div>
            </div>

            <Card>
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-lg font-semibold">Из печатной накладной → в компьютерные данные</h3>
                  <div class="mt-1 text-sm text-slate-600">
                    Фото/скан/pdf документа → AI-анализ → CRM / ERP / 
                    учётные и любые другие программы
                  </div>
                </div>
              </div>

              <div class="mt-4 rounded-2xl bg-slate-50 ring-1 ring-slate-200 overflow-hidden">
                <img src="/assets/best_image_for_site2.png" alt="Из накладной в данные" class="w-full" loading="lazy" />
              </div>
            </Card>
          </FlexGrid>
        </Container>
      </Section>

      <!-- Benefits -->
      <Section id="benefits" padding="small">
        <Container>
          <h2 class="h2">Выгоды для бизнеса</h2>
          <p class="p mt-2">
            <b>Основной эффект — экономия денег, быстрое поступление данных, минимизация ошибок, контроль и дальнейшая работа с данными.</b>
          </p>

          <FlexGrid cols={4} gap="md" class="mt-8">
            <Card variant="feature">
              <div class="text-base font-semibold">Меньше работы = меньше затрат</div>
              <p class="p mt-2 text-sm">
              <!--
              Рутинный ввод уходит: меньше операторов 
              — или те же люди делают более ценную работу.
              -->
              Снижаем стоимость обработки документа: меньше ручного труда
              </p>
            </Card>

            <Card variant="feature">
              <div class="text-base font-semibold">Минимизация ошибок</div>
              <p class="p mt-2 text-sm">
                <!--DocLogic извлекает данные и показывает их в обычной web-форме. 
                Если заметили неточность — быстро правите и сохраняете.
                -->
                Проверки перед выгрузкой: суммы, цены, дубли, обязательные 
                поля — в систему попадает только корректное
              </p>
            </Card>

            <Card variant="feature">
              <div class="text-base font-semibold">Ускорение закрытия поступлений</div>
              <p class="p mt-2 text-sm">Данные быстрее попадают в систему — склад и бухгалтерия работают синхронно.</p>
            </Card>

            <Card variant="feature">
              <div class="text-base font-semibold">Полная настройка программы для вас</div>
              <p class="p mt-2 text-sm">Интеграция в вашу систему + доработки под ваш процесс (по договорённости на внедрении).</p>
            </Card>
          </FlexGrid>
        </Container>
      </Section>



<!-- ROI / Экономия -->
<Section id="roi" padding="small">
  <Container>
    <div class="max-w-3xl">
      <h2 class="h2">Оценка экономии за 30 секунд</h2>
      <p class="p mt-2">
        Введите примерные цифры — покажем экономию денег и эффект по ошибкам.
        Можно округлить: точность уточним на демо по вашим документам.
      </p>
    </div>

    <FlexGrid cols={2} gap="lg" items="start" class="mt-8 lg:grid-cols-2">
      <!-- Inputs -->
      <Card>
        <div class="text-lg font-semibold">Ваши цифры</div>
        <p class="mt-1 text-sm text-slate-600">
          Никаких «минимальных объёмов»: выгода зависит от времени ручной обработки и стоимости ошибок.
        </p>

        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div class="sm:col-span-2">
            <label class="text-sm font-medium" for="roi_docs">Документов в месяц (примерно)</label>
            <input
              id="roi_docs"
              inputmode="numeric"
              class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm"
              placeholder="например: 80 / 200 / 500 / 2000"
            />
          </div>

          <div>
            <label class="text-sm font-medium" for="roi_minutes">Минут на документ сейчас</label>
            <input
              id="roi_minutes"
              inputmode="decimal"
              class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm"
              placeholder="например: 3–10"
            />
          </div>

          <div>
            <label class="text-sm font-medium" for="roi_rate">Стоимость часа сотрудника, €</label>
            <input
              id="roi_rate"
              inputmode="decimal"
              class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm"
              placeholder="например: 15–30"
            />
          </div>

          <div>
            <label class="text-sm font-medium" for="roi_errors">Ошибок в месяц (опционально)</label>
            <input
              id="roi_errors"
              inputmode="numeric"
              class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm"
              placeholder="например: 2 / 10 / 30"
            />
          </div>

          <div>
            <label class="text-sm font-medium" for="roi_error_cost">Цена одной ошибки, € (опционально)</label>
            <input
              id="roi_error_cost"
              inputmode="decimal"
              class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm"
              placeholder="например: 20 / 80 / 200"
            />
          </div>
        </div>

        <details class="mt-4 rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
          <summary class="cursor-pointer text-sm font-semibold text-slate-900">Допущения расчёта</summary>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            <div class="sm:col-span-2 text-sm text-slate-600">
              После DocLogic сотрудник обычно подтверждает результат и правит только исключения.
            </div>
            <div>
              <label class="text-sm font-medium" for="roi_after">Минут на проверку после DocLogic</label>
              <input
                id="roi_after"
                inputmode="decimal"
                class="mt-2 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm"
                value="0.5"
              />
              <div class="mt-1 text-xs text-slate-500">По умолчанию: 0.5 мин (30 сек)</div>
            </div>
          </div>
        </details>

        <div class="mt-5 flex flex-wrap gap-3">
          <a href="#request" class="btn btn-primary">Получить расчёт и демо на моих документах</a>
          <button id="roi_reset" type="button" class="btn">Сбросить</button>
        </div>

        <div id="roi_hint" class="small mt-3 text-slate-500">
          Подсказка: если документов мало — экономия часто появляется за счёт дорогих ошибок и сложных документов.
        </div>
      </Card>

      <!-- Outputs -->
      <Card>
        <div class="text-lg font-semibold">Результат</div>
        <p class="mt-1 text-sm text-slate-600">
          Это оценка. Точный расчёт сделаем после 5–10 ваших документов и покажем выгрузку “как вам нужно”.
        </p>

        <div class="mt-5 grid gap-3">
          <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
            <div class="text-sm font-semibold text-slate-600">Экономия времени</div>
            <div id="roi_out_hours" class="mt-1 text-2xl font-bold">—</div>
            <div id="roi_out_hours_sub" class="mt-1 text-xs text-slate-500">часов/мес</div>
          </div>

          <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
            <div class="text-sm font-semibold text-slate-600">Экономия на ручной обработке</div>
            <div id="roi_out_labor" class="mt-1 text-2xl font-bold">—</div>
            <div class="mt-1 text-xs text-slate-500">€/мес</div>
          </div>

          <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
            <div class="text-sm font-semibold text-slate-600">Экономия на ошибках</div>
            <div id="roi_out_errors" class="mt-1 text-2xl font-bold">—</div>
            <div class="mt-1 text-xs text-slate-500">€/мес</div>
          </div>

          <div class="rounded-2xl bg-white ring-1 ring-slate-200 p-4">
            <div class="text-sm font-semibold text-slate-600">Итого потенциальная выгода</div>
            <div id="roi_out_total" class="mt-1 text-3xl font-bold">—</div>
            <div class="mt-1 text-xs text-slate-500">€/мес</div>
          </div>

          <div class="rounded-2xl bg-slate-50 ring-1 ring-slate-200 p-4">
            <div class="text-sm font-semibold">Комментарий</div>
            <div id="roi_msg" class="mt-2 text-sm text-slate-700">
              Введите цифры слева — мы покажем оценку экономии.
            </div>
          </div>
        </div>
      </Card>
    </FlexGrid>

    <script is:inline>
      (function () {
        const $ = (id) => document.getElementById(id);

        const elDocs = $('roi_docs');
        const elMin = $('roi_minutes');
        const elRate = $('roi_rate');
        const elAfter = $('roi_after');
        const elErr = $('roi_errors');
        const elErrCost = $('roi_error_cost');
        const btnReset = $('roi_reset');

        const outHours = $('roi_out_hours');
        const outLabor = $('roi_out_labor');
        const outErrors = $('roi_out_errors');
        const outTotal = $('roi_out_total');
        const outMsg = $('roi_msg');

        const fmtEur = new Intl.NumberFormat('ru-RU', {
          style: 'currency',
          currency: 'EUR',
          maximumFractionDigits: 0,
        });

        const fmtNum = new Intl.NumberFormat('ru-RU', { maximumFractionDigits: 1 });

        const parse = (v) => {
          if (v == null) return NaN;
          const s = String(v).trim().replace(/\s+/g, '').replace(',', '.');
          if (!s) return NaN;
          const n = Number(s);
          return Number.isFinite(n) ? n : NaN;
        };

        const clamp0 = (n) => (Number.isFinite(n) && n > 0 ? n : 0);

        const setDash = () => {
          outHours.textContent = '—';
          outLabor.textContent = '—';
          outErrors.textContent = '—';
          outTotal.textContent = '—';
        };

        const update = () => {
          const N = parse(elDocs.value);
          const Tm = parse(elMin.value);
          const R = parse(elRate.value);
          const Ta = parse(elAfter.value);

          const E = parse(elErr.value);
          const Ec = parse(elErrCost.value);

          // Need at least these three to compute labor ROI
          const canLabor = Number.isFinite(N) && N > 0 && Number.isFinite(Tm) && Tm > 0 && Number.isFinite(R) && R > 0 && Number.isFinite(Ta) && Ta >= 0;

          if (!canLabor) {
            setDash();
            outMsg.textContent = 'Введите документы/месяц, минуты на документ и стоимость часа — покажем оценку экономии.';
            return;
          }

          const docs = clamp0(N);
          const minutesManual = clamp0(Tm);
          const rate = clamp0(R);
          const minutesAfter = Math.max(0, Number.isFinite(Ta) ? Ta : 0.5);

          // Manual workload (for message A/B/C)
          const manualHours = (docs * minutesManual) / 60;

          // Savings (labor)
          const minutesSavedPerDoc = Math.max(0, minutesManual - minutesAfter);
          const hoursSaved = (docs * minutesSavedPerDoc) / 60;
          const laborEur = hoursSaved * rate;

          // Savings (errors) — only if both inputs present
          const hasErrorInputs = Number.isFinite(E) && E > 0 && Number.isFinite(Ec) && Ec > 0;
          const errorsEur = hasErrorInputs ? E * Ec : 0;

          const totalEur = laborEur + errorsEur;

          outHours.textContent = fmtNum.format(hoursSaved);
          outLabor.textContent = fmtEur.format(laborEur);
          outErrors.textContent = hasErrorInputs ? fmtEur.format(errorsEur) : '—';
          outTotal.textContent = fmtEur.format(totalEur);

          // A/B/C message by manual hours (NOT by N_docs)
          let msg = '';
          if (manualHours < 10) {
            msg =
              'При небольшой нагрузке выгода чаще всего появляется за счёт дорогих ошибок и сложных документов. ' +
              'Пришлите 5–10 примеров — покажем, есть ли экономический смысл именно у вас.';
          } else if (manualHours < 40) {
            msg =
              'Чаще всего это уже окупается за счёт экономии времени + снижения ошибок. ' +
              'На демо покажем выгрузку “как вам нужно” и сделаем точный расчёт.';
          } else {
            msg =
              'При такой нагрузке эффект обычно максимальный: меньше ручной работы и меньше разборов из-за ошибок. ' +
              'Давайте быстро сделаем пилот на ваших документах — результат увидите сразу.';
          }

          // If user didn’t enter error part, nudge gently
          if (!hasErrorInputs) {
            msg += ' Добавьте “ошибок/месяц” и “цену ошибки” — тогда расчёт станет ещё точнее.';
          }

          outMsg.textContent = msg;
        };

        const bind = (el) => el && el.addEventListener('input', update);

        [elDocs, elMin, elRate, elAfter, elErr, elErrCost].forEach(bind);

        btnReset?.addEventListener('click', () => {
          elDocs.value = '';
          elMin.value = '';
          elRate.value = '';
          elErr.value = '';
          elErrCost.value = '';
          elAfter.value = '0.5';
          setDash();
          outMsg.textContent = 'Введите цифры слева — мы покажем оценку экономии.';
        });

        // init
        setDash();
        update();
      })();
    </script>
  </Container>
</Section>




      <!-- Examples -->
      <Section id="examples">
        <Container>
          <h2 class="h2">Примеры документов</h2>

          <FlexGrid cols={4} gap="md" class="mt-8">
            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/invoice.jpg" alt="Пример накладной" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>

            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/ford.jpeg" alt="Пример товарной накладной" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>

            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/french.jpg" alt="Пример накладной на иностранном языке" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>

            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/gastro.jpg" alt="Пример товарной накладной" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>

            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/lunys.jpg" alt="Пример товарной накладной" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>

            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/camozzi.jpg" alt="Пример товарной накладной" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>

            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/metro.jpg" alt="Пример товарной накладной" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>

            <Card class="overflow-hidden p-0">
              <div class="w-full aspect-[210/297] bg-white flex items-start justify-center">
                <img src="/assets/web/ttn.jpeg" alt="Пример товарной накладной" class="max-w-full max-h-full w-auto h-auto object-contain" loading="lazy" />
              </div>
            </Card>
          </FlexGrid>
        </Container>
      </Section>

      <!-- How -->
      <Section id="how">
        <Container>
          <h2 class="h2">Как DocLogic работает</h2>
          <p class="p mt-2"><b>Вход — накладная (фото/скан/PDF), выход — готовые данные в вашу систему.</b></p>

          <FlexGrid cols={4} gap="md" class="mt-8">
            <Card variant="feature">
              <div class="badge">Шаг 1</div>
              <div class="mt-3 text-lg font-semibold">Загружаете накладную</div>
              <div class="p mt-2 text-sm">Скан, фото или PDF</div>
            </Card>

            <Card variant="feature">
              <div class="badge">Шаг 2</div>
              <div class="mt-3 text-lg font-semibold">Программа анализирует документ и собирает данные</div>
              <div class="p mt-2 text-sm">Извлекаем <b>все нужные поля</b> из документа.</div>
            </Card>

            <Card variant="feature">
