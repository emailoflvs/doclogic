---
import '../styles/global.css';
import Section from '../components/Section.astro';
import Container from '../components/Container.astro';
import FlexGrid from '../components/FlexGrid.astro';
import Card from '../components/Card.astro';

const year = new Date().getFullYear();
const buildId = new Date().toISOString().slice(0, 19).replace('T', ' ');
const fallbackYoutubeId = 'D0UoSqo5kzo';
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="build-time" content={new Date().toISOString()} />

    <title>DocLogic — уберите ручной ввод данных из документов</title>
    <meta
      name="description"
      content="Программа 
      извлекает реквизиты и товары из фото/сканов/PDF накладных. 
      Сохраняет результат в CRM, ERP и любые другие программы."
    />
    <link rel="icon" href="/assets/favicon.svg" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2ELPJTJDBJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag(){ window.dataLayer.push(arguments); };
      window.gtag('js', new Date());
      window.gtag('config', 'G-2ELPJTJDBJ');

      window.dlTrack = function (eventName, params = {}) {
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, params);
        }
      };

      window.dlAttributionStorageKey = 'dl_attribution_v1';

      window.dlReadAttribution = function () {
        try {
          return JSON.parse(localStorage.getItem(window.dlAttributionStorageKey) || '{}') || {};
        } catch {
          return {};
        }
      };

      window.dlWriteAttribution = function (value) {
        try {
          localStorage.setItem(window.dlAttributionStorageKey, JSON.stringify(value || {}));
        } catch {}
      };

      window.dlGetAttribution = window.dlReadAttribution;
    </script>

    <style is:global>
      .nav-link {
        position: relative;
        padding: 6px 0;
        transition: color 150ms ease;
      }
      .nav-link--active {
        color: #0f172a !important;
        font-weight: 600;
      }
      .nav-link--active::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -10px;
        height: 2px;
        background: rgba(15, 23, 42, 0.85);
        border-radius: 999px;
      }
    </style>
  </head>

  <body>
    <header class="sticky top-0 z-50 border-b border-slate-200/70 bg-white/85 backdrop-blur">
      <div class="container flex h-16 items-center justify-between gap-4">
        <a href="#top" class="flex items-center gap-3 shrink-0">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-slate-900 text-white font-bold">DL</span>
          <span class="font-semibold">DocLogic</span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm text-slate-600">
          <a class="nav-link hover:text-slate-900" href="#roi">Калькулятор расходов</a>
          <a class="nav-link hover:text-slate-900" href="#how">Как работает</a>
          <a class="nav-link hover:text-slate-900" href="#setup">Настройка</a>
          <a class="nav-link hover:text-slate-900" href="#pricing">Цена</a>
          <a class="nav-link hover:text-slate-900" href="#faq">FAQ</a>
        </nav>

        <a
          class="btn btn-primary hidden sm:inline-flex"
          href="#request"
          data-ga-event="cta_click"
          data-ga-placement="header"
          data-ga-label="Анализ на ваших документах"
        >
          Анализ на ваших документах
        </a>
      </div>
    </header>

    <main id="top">
      <Section padding="none" class="pt-2 pb-6 md:pt-3 md:pb-10">
        <Container>
          <FlexGrid cols={2} gap="lg" items="start" class="lg:grid-cols-[1fr,1fr]">
            <div>
              <div class="badge">AI для входящих документов</div>

              <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight leading-[1.02] max-w-3xl">
                Перестаньте платить за ввод данных
              </h1>

              <p class="p mt-5 max-w-2xl text-lg text-slate-700">
                Сотрудник больше не вводит данные вручную.
                <br>
                DocLogic сокращает рутину, 
                уменьшает ошибки и ускоряет закрытие поступлений.
              </p>

              <div class="mt-6 space-y-3 max-w-2xl">
                <div class="hero-point"><span></span>Экономия на вводе данных</div>
